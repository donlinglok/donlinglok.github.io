}

@media (max-width: 240px) {
  button { padding-left: 12px; padding-right: 12px; }
  .interstitial-wrapper { overflow: inherit; padding: 0px 8px; }
}

@media (max-width: 120px) {
  button { width: auto; }
}

.arcade-mode, .arcade-mode .runner-container, .arcade-mode .runner-canvas {=
 image-rendering: pixelated; max-width: 100%; overflow: hidden; }

