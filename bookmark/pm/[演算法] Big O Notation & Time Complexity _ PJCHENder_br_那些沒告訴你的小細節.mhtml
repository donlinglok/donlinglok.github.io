 * Big O Notation: "O(1)"
 **/
function log (arr) {
  console.log(arr[0])
  console.log(arr[1])
}
log(arr1)    // 1, 2
log(arr2)    // 1, 2


/**
 * Linear Run Time: =E9=9A=A8=E8=91=97=E8=B3=87=E6=96=99=E9=87=8F=E7=9A=84=
=E5=A2=9E=E5=8A=A0=EF=BC=8C=E5=9F=B7=E8=A1=8C=E6=99=82=E9=96=93=E6=9C=83=E7=
=AD=89=E6=AF=94=E5=A2=9E=E5=8A=A0
 * Big O Notation: "O(n)"
 **/
function logAll (arr) {
  for (let item of arr) {
    console.log(item)
  }
}

logAll(arr1)  // 1, 2, 3, 4, 5
