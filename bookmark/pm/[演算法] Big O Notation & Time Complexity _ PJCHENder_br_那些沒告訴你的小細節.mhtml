 * Big O Notation: "O (log n)"
 **/
function binarySearch (arr, key) {
  let low =3D 0
  let high =3D arr.length - 1
  let mid
  let element
 =20
  while (low &lt;=3D high) {
    mid =3D Math.floor((low + high) / 2, 10)
    element =3D arr[mid]
    console.log('ele', mid, element)
    if (element &lt; key) {
      low =3D mid + 1
    } else if (element &gt; key) {
      high =3D mid - 1
    } else {
